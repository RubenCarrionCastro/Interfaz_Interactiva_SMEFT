           RowBox[{"startDir", "===", "Automatic"}], ",", 
           RowBox[{"NotebookDirectory", "[", "]"}], ",", "startDir"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"files", "=", 
