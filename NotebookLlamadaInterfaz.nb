       RowBox[{
        RowBox[{"dir", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"startDir", "===", "Automatic"}], ",", 
           RowBox[{"NotebookDirectory", "[", "]"}], ",", "startDir"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"files", "=", 
         RowBox[{"FileNames", "[", 
          RowBox[{"fileName", ",", "dir", ",", "Infinity"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "files", "]"}], ">", "0"}], ",", 
          RowBox[{"First", "[", "files", "]"}], ",", "$Failed"}], "]"}]}]}], 
